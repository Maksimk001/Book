<Page x:Class="Book.Resourses.Pages.EditOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Book.Resourses.Pages"
      mc:Ignorable="d" 
      Loaded="Page_Loaded"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="EditOrder">
    <Grid Background="White">
        <StackPanel Margin="20" HorizontalAlignment="Center">

            <TextBlock Text="Дата доставки"/>
            <DatePicker x:Name="deliveryDatePicker" Width="250"/>

            <TextBlock Text="Пункт выдачи" Margin="0,10,0,0"/>
            <ComboBox x:Name="pickup"
                      Width="250"
                      DisplayMemberPath="FullAddress"
                      SelectedValuePath="id"/>

            <TextBlock Text="Заказчик" Margin="0,10,0,0"/>
            <ComboBox x:Name="user"
                      Width="250"
                      DisplayMemberPath="FullName"
                      SelectedValuePath="id"/>

            <TextBlock Text="Код получения" Margin="0,10,0,0"/>
            <TextBox x:Name="code" Width="250"/>

            <StackPanel Orientation="Horizontal" Margin="0,20,0,0" HorizontalAlignment="Center">
                <Button Content="Сохранить" Width="100" Margin="5" Click="Save_Click"/>
                <Button Content="Назад" Width="100" Margin="5" Click="Back_Click"/>
            </StackPanel>

        </StackPanel>
    </Grid>
</Page>
