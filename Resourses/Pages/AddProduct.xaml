<Page x:Class="Book.Resourses.Pages.AddProduct"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Book.Resourses.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddProduct">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <Button Content="Вернуться назад" Click="GoBack_Click"/>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
                <TextBlock FontSize="16" FontWeight="Bold" Text="Добавить товар"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Center">
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Grid.Row="1" HorizontalAlignment="Center">
                <TextBlock Text="Введите артикул:" Margin="0 10 0 0"/>
                <TextBox x:Name="art" Width="200"/>

                <TextBlock Text="Введите название:" Margin="0 10 0 0"/>
                <TextBox x:Name="name" Width="200"/>

                <TextBlock Text="Укажите цену:" Margin="0 10 0 0"/>
                <TextBox x:Name="price" Width="200"/>

                <TextBlock Text="Выберите ед. измерения:" Margin="0 10 0 0"/>
                <ComboBox x:Name="CmbEd" DisplayMemberPath="name"/>

                <TextBlock Text="Выберите поставщика:" Margin="0 10 0 0"/>
                <ComboBox x:Name="CmbProviders" DisplayMemberPath="name"/>

                <TextBlock Text="Выберите производителя:" Margin="0 10 0 0"/>
                <ComboBox x:Name="CmdManuf" DisplayMemberPath="name"/>

                <TextBlock Text="Выберите категорию:" Margin="0 10 0 0"/>
                <ComboBox x:Name="CmdCategory" DisplayMemberPath="name"/>

                <TextBlock Text="Введите скидку:" Margin="0 10 0 0"/>
                <TextBox x:Name="sale" Width="200"/>

                <TextBlock Text="Введите количество:" Margin="0 10 0 0"/>
                <TextBox x:Name="quantity" Width="200"/>

                <TextBlock Text="Введите описание:" Margin="0 10 0 0"/>
                <TextBox x:Name="description" Width="200"/>

                <Image x:Name="ProductImage" Width="80" Height="40" Margin="0 10"/>
                <Button Content="Выбрать фото" Click="SelectImage_Click"/>

                <Button Content="Добавить" Margin="0 10 0 0" Click="AddBtn_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
