<Page x:Class="Book.Resourses.Pages.AddOrder"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Book.Resourses.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AddOrder">

    <Grid Background="White">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid VerticalAlignment="Center">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Content="Выход" Width="100" Height="25" HorizontalAlignment="Left" Margin="0 0 0 0" Click="LogOut_Click"/>
            <TextBlock Grid.Column="1" x:Name="NameUser" Text="Имя" HorizontalAlignment="Right"/>
        </Grid>
        
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="10">
            <TextBlock FontSize="16" FontWeight="Bold" Text="Добавить заказ"/>
        </StackPanel>

        <ScrollViewer Grid.Row="2"  VerticalScrollBarVisibility="Auto">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="Укажите дату доставки" Margin="0 10 0 0" Width="250"/>
                <DatePicker x:Name="deliveryDatePicker" Width="250"/>

                <TextBlock Text="Укажите пункт выдачи" Width="250"/>
                <ComboBox x:Name="pickup" Width="250" DisplayMemberPath="FullAddress"/>

                <TextBlock Text="Укажите заказчика" Width="250"/>
                <ComboBox x:Name="user" Width="250" DisplayMemberPath="FullName"/>

                <TextBlock Text="Укажите код получения" Width="250"/>
                <TextBox x:Name="code" Width="250"/>

                <DataGrid x:Name="ProductsGrid" AutoGenerateColumns="False" Height="200" Margin="5">

                    <DataGrid.Columns>

                        <DataGridTextColumn Header="Название" Binding="{Binding name}" Width="*"/>

                        <DataGridTextColumn Header="Цена" Binding="{Binding price}" Width="100"/>

                        <DataGridTemplateColumn Header="Кол-во">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Count, Mode=TwoWay}" Width="50"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>

                    </DataGrid.Columns>
                </DataGrid>
                <Button Content="Создать заказ" Width="250" Click="Save_Click"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>

</Page>
